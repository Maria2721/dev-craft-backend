# App
PORT=<your_port>
CORS_ORIGIN=<your_cors_origin>

# Public hostname for TLS (Caddy + Let's Encrypt)
PUBLIC_DOMAIN=<your_domain>

# PostgreSQL
POSTGRES_USER=<your_postgres_user>
POSTGRES_PASSWORD=<your_postgres_password>
POSTGRES_DB=<your_postgres_db>
POSTGRES_HOST_PORT=<your_postgres_host_port>

# Prisma
DATABASE_URL="postgresql://user:password@localhost:port/db"

# JWT (auth)
JWT_ACCESS_SECRET=<your_jwt_access_secret>
JWT_ACCESS_TTL=900
JWT_REFRESH_SECRET=<your_jwt_refresh_secret>
JWT_REFRESH_TTL=604800

# LLM provider: api_llm | local_llm | dify_chatflow
# AI_LLM_PROVIDER=api_llm
# AI_MAX_MESSAGE_LENGTH=4000
# AI_MAX_REQUESTS_PER_DAY=1000

# api_llm: DeepSeek, Groq, Gemini, etc.
# AI_API_KEY=<your_api_key>
# AI_API_BASE_URL=https://api.deepseek.com
# AI_API_MODEL=deepseek-chat

# local_llm: Ollama, Qwen, etc.
# AI_LOCAL_BASE_URL=http://localhost:11434
# AI_LOCAL_MODEL=llama3.2

# dify_chatflow
AI_DIFY_BASE_URL=https://api.dify.ai/v1
AI_DIFY_APP_API_KEY=app-xxxxx
AI_DIFY_END_USER=<your_user>
AI_DIFY_USE_CONTEXT_INPUTS=false

# MCP (Dify Tools -> MCP, Path: /mcp)
MCP_BEARER_TOKEN=<your_token>

# Swagger (basic auth for /openapi)
SWAGGER_USER=admin
SWAGGER_PASSWORD=<your_swagger_password>
