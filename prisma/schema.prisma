generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int               @id @default(autoincrement())
  name             String
  surname          String
  email            String            @unique
  passwordHash     String
  createdAt        DateTime          @default(now())
  conversations    Conversation[]
  questionAttempts QuestionAttempt[]
  codeTaskAttempts CodeTaskAttempt[]

  @@map("users")
}

model Conversation {
  id                 String    @id @default(uuid())
  userId             Int
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskId             String?
  taskType           String?
  taskTitle          String?
  difyConversationId String?
  discordChannelId   String?
  discordUserId      String?
  messages           Message[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([userId])
  @@index([discordChannelId, discordUserId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String       @db.Text
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@map("messages")
}

enum QuestionType {
  SINGLE_CHOICE
  MULTIPLE_CHOICE
}

enum CodeTaskType {
  AI_CHECK
  DRAG_DROP
}

model Topic {
  id               String            @id @default(uuid())
  slug             String            @unique
  title            String
  description      String?
  order            Int
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  questions        Question[]
  codeTasks        CodeTask[]
  questionAttempts QuestionAttempt[]
  codeTaskAttempts CodeTaskAttempt[]

  @@index([order])
  @@map("topics")
}

model Question {
  id          String            @id @default(uuid())
  topicId     String
  topic       Topic             @relation(fields: [topicId], references: [id])
  prompt      String            @db.Text
  codeSnippet String?           @db.Text
  type        QuestionType
  order       Int
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  options     QuestionOption[]
  attempts    QuestionAttempt[]

  @@index([topicId, order])
  @@map("questions")
}

model QuestionOption {
  id         String   @id @default(uuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id])
  label      String
  text       String
  isCorrect  Boolean
  order      Int

  @@index([questionId, order])
  @@map("question_options")
}

model CodeTask {
  id                String            @id @default(uuid())
  topicId           String
  topic             Topic             @relation(fields: [topicId], references: [id])
  title             String
  description       String            @db.Text
  taskType          CodeTaskType
  referenceSolution String?           @db.Text
  order             Int
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  codeTaskAttempts  CodeTaskAttempt[]

  @@index([topicId, order])
  @@map("code_tasks")
}

model CodeTaskAttempt {
  id            String   @id @default(uuid())
  userId        Int
  user          User     @relation(fields: [userId], references: [id])
  topicId       String
  topic         Topic    @relation(fields: [topicId], references: [id])
  codeTaskId    String
  codeTask      CodeTask @relation(fields: [codeTaskId], references: [id])
  valid         Boolean
  hints         String?  @db.Text
  justification String?  @db.Text
  improvements  String?  @db.Text
  createdAt     DateTime @default(now())

  @@index([userId, topicId])
  @@index([codeTaskId])
  @@map("code_task_attempts")
}

model QuestionAttempt {
  id                String   @id @default(uuid())
  userId            Int
  user              User     @relation(fields: [userId], references: [id])
  topicId           String
  topic             Topic    @relation(fields: [topicId], references: [id])
  questionId        String
  question          Question @relation(fields: [questionId], references: [id])
  selectedOptionIds String[]
  isCorrect         Boolean
  createdAt         DateTime @default(now())

  @@index([userId, topicId])
  @@index([questionId])
  @@map("question_attempts")
}
